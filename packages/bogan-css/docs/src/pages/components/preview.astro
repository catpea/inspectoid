---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Snippet from "../../components/Snippet.astro";
---

<BaseLayout title="Canvas & Preview" description="Isolated story rendering surface with dot-grid background, preview frame card, loading overlay, and fullscreen mode.">

  <!-- Canvas with preview frame -->
  <h2 class="h5 mb-3">Canvas</h2>
  <p class="cf-muted">The <code>.cf-canvas</code> fills the center column and uses a subtle dot-grid to visually distinguish the rendering surface from the chrome around it.</p>
  <section class="cf-canvas rounded border mb-2" style="min-height:16rem; border-radius: .75rem !important">
    <div class="cf-preview-frame">
      <div class="cf-preview-card">
        <div class="d-flex align-items-center justify-content-between gap-3">
          <div>
            <span class="badge text-bg-primary mb-2">Button</span>
            <h2 class="h5 mb-1">Primary Button</h2>
            <p class="cf-muted mb-0">Isolated story preview.</p>
          </div>
          <button class="btn btn-primary" type="button"><i class="bi bi-lightning-charge me-1"></i>Click me</button>
        </div>
        <hr>
        <div class="d-flex flex-wrap gap-2">
          <button class="btn btn-primary" type="button">Primary</button>
          <button class="btn btn-outline-primary" type="button">Outline</button>
          <button class="btn btn-primary" type="button" disabled>Disabled</button>
          <button class="btn btn-sm btn-primary" type="button">Small</button>
          <button class="btn btn-lg btn-primary" type="button">Large</button>
        </div>
      </div>
    </div>
  </section>

  <Snippet language="html" code={`<section class="cf-canvas">
  <div class="cf-preview-frame">
    <div class="cf-preview-card">
      <!-- Story content here -->
      <button class="btn btn-primary">Button</button>
    </div>
  </div>
</section>`} />

  <!-- Dark canvas -->
  <h2 class="h5 mt-5 mb-3">Dark Canvas</h2>
  <p class="cf-muted">Add <code>.is-dark</code> to <code>.cf-canvas</code> for a dark background when previewing dark-themed components. The grid adapts to white lines.</p>
  <section class="cf-canvas is-dark rounded border mb-2" style="min-height:12rem; border-radius: .75rem !important" data-bs-theme="dark">
    <div class="cf-preview-frame">
      <div class="cf-preview-card">
        <div class="d-flex flex-wrap gap-2">
          <button class="btn btn-primary" type="button">Primary</button>
          <button class="btn btn-outline-light" type="button">Light outline</button>
          <button class="btn btn-secondary" type="button">Secondary</button>
        </div>
      </div>
    </div>
  </section>

  <Snippet language="html" code={`<section class="cf-canvas is-dark" data-bs-theme="dark">
  …
</section>`} />

  <!-- Preview frame vs preview card -->
  <h2 class="h5 mt-5 mb-3">Preview Frame vs Preview Card</h2>
  <div class="row g-3 mb-2">
    <div class="col-md-6">
      <p class="cf-muted small mb-2"><code>.cf-preview-frame</code> — floating panel, centered in canvas. Max width 42rem.</p>
      <div class="cf-preview-frame">
        <p class="mb-2">Frame content</p>
        <button class="btn btn-sm btn-primary">Action</button>
      </div>
    </div>
    <div class="col-md-6">
      <p class="cf-muted small mb-2"><code>.cf-preview-card</code> — flat bordered box for source code and embedded examples.</p>
      <div class="cf-preview-card cf-mono">
        <code>&lt;button class="btn btn-primary"&gt;Click&lt;/button&gt;</code>
      </div>
    </div>
  </div>

  <!-- Loading overlay -->
  <h2 class="h5 mt-5 mb-3">Loading Overlay</h2>
  <p class="cf-muted">Shown during story navigation. Positioned <code>inset:0</code> over the canvas. Toggle <code>.is-visible</code> to show it.</p>
  <section class="cf-canvas rounded border mb-2" style="min-height:10rem; position:relative; border-radius: .75rem !important">
    <div class="cf-preview-frame">
      <p class="cf-muted">Story content behind overlay</p>
    </div>
    <div class="cf-loading-overlay is-visible" style="border-radius: .75rem">
      <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading…</span>
      </div>
    </div>
  </section>

  <Snippet language="html" code={`<section class="cf-canvas">
  <div class="cf-preview-frame">…</div>

  <!-- Hidden by default; add .is-visible to show -->
  <div class="cf-loading-overlay is-visible" aria-live="polite">
    <div class="spinner-border text-primary" role="status">
      <span class="visually-hidden">Loading…</span>
    </div>
  </div>
</section>`} />

  <!-- Fullscreen mode -->
  <h2 class="h5 mt-5 mb-3">Fullscreen Mode</h2>
  <p class="cf-muted">Add <code>.is-fullscreen</code> to <code>.cf-workbench</code> to collapse the sidebar, docs panel, and addon panel — canvas fills the whole center. <code>components.js</code> toggles this via <code>[data-cf-fullscreen]</code>.</p>
  <Snippet language="html" code={`<!-- Toggle fullscreen via data attribute -->
<button class="btn btn-sm btn-outline-secondary cf-icon-button"
        type="button" data-cf-fullscreen aria-label="Fullscreen" aria-pressed="false">
  <i class="bi bi-arrows-fullscreen"></i>
</button>

<!-- Or add the class manually -->
<div class="cf-workbench is-fullscreen">…</div>`} />

  <!-- Classes reference -->
  <h2 class="h5 mt-5 mb-3">Classes</h2>
  <table class="cf-props-table">
    <thead><tr><th>Class</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td>.cf-canvas</td><td>Grid center for story. Dot-grid background. Add <code>.is-dark</code> for dark theme.</td></tr>
      <tr><td>.cf-preview-frame</td><td>Elevated white panel (max-w 42rem) centered in the canvas. Uses <code>cf-panel</code> mixin.</td></tr>
      <tr><td>.cf-preview-card</td><td>Flat bordered card inside frames. Used for source code blocks and inline examples.</td></tr>
      <tr><td>.cf-loading-overlay</td><td>Absolute overlay over canvas. Hidden by default; add <code>.is-visible</code> to display.</td></tr>
    </tbody>
  </table>

</BaseLayout>
