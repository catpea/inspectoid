---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Design Tokens" description="The color palette, typography scale, spacing rhythm, and shadow system behind Components FantasyUI.">

  <!-- Color palette -->
  <h2 class="h5 mb-3">Color Palette</h2>
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="cf-quality-card">
        <div class="mb-2 rounded" style="height:3rem; background: var(--cf-primary)"></div>
        <div class="cf-muted small">Primary</div>
        <strong style="color: var(--cf-primary)">#ff4785</strong>
        <div class="cf-muted small mt-1">$cf-primary</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="cf-quality-card">
        <div class="mb-2 rounded" style="height:3rem; background: var(--cf-accent)"></div>
        <div class="cf-muted small">Accent</div>
        <strong style="color: var(--cf-accent)">#1ea7fd</strong>
        <div class="cf-muted small mt-1">$cf-accent</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="cf-quality-card">
        <div class="mb-2 rounded" style="height:3rem; background: var(--cf-success)"></div>
        <div class="cf-muted small">Success</div>
        <strong style="color: var(--cf-success)">#2fbf71</strong>
        <div class="cf-muted small mt-1">$cf-success</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="cf-quality-card">
        <div class="mb-2 rounded" style="height:3rem; background: var(--cf-warning)"></div>
        <div class="cf-muted small">Warning</div>
        <strong style="color: var(--cf-warning)">#f3aa35</strong>
        <div class="cf-muted small mt-1">$cf-warning</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="cf-quality-card">
        <div class="mb-2 rounded" style="height:3rem; background: var(--cf-danger)"></div>
        <div class="cf-muted small">Danger</div>
        <strong style="color: var(--cf-danger)">#ed5a5a</strong>
        <div class="cf-muted small mt-1">$cf-danger</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="cf-quality-card">
        <div class="mb-2 rounded" style="height:3rem; background: var(--cf-surface)"></div>
        <div class="cf-muted small">Surface</div>
        <strong>Cards &amp; chrome</strong>
        <div class="cf-muted small mt-1">--cf-surface</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="cf-quality-card">
        <div class="mb-2 rounded border" style="height:3rem; background: var(--cf-surface-2)"></div>
        <div class="cf-muted small">Surface 2</div>
        <strong>Inset areas</strong>
        <div class="cf-muted small mt-1">--cf-surface-2</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="cf-quality-card">
        <div class="mb-2 rounded" style="height:3rem; background: var(--cf-bg)"></div>
        <div class="cf-muted small">Background</div>
        <strong>App canvas</strong>
        <div class="cf-muted small mt-1">--cf-bg</div>
      </div>
    </div>
  </div>

  <!-- Ink scale (dark text palette) -->
  <h2 class="h5 mb-3">Ink Scale</h2>
  <div class="d-flex gap-2 mb-4 flex-wrap">
    {[
      ["#0b1020", "950"],
      ["#121827", "900"],
      ["#1c2537", "800"],
      ["#2b364a", "700"],
      ["#46556f", "600"],
    ].map(([color, step]) => (
      <div class="d-flex flex-column align-items-center gap-1">
        <div class="rounded" style={`width:3rem;height:3rem;background:${color}`}></div>
        <span class="cf-muted" style="font-size:.72rem">{step}</span>
      </div>
    ))}
  </div>

  <!-- CSS custom properties -->
  <h2 class="h5 mb-3">CSS Custom Properties</h2>
  <p class="cf-muted">These are set on <code>:root</code> and updated under <code>[data-bs-theme="dark"]</code>.</p>
  <table class="cf-props-table mb-4">
    <thead><tr><th>Variable</th><th>Light</th><th>Dark</th></tr></thead>
    <tbody>
      <tr><td>--cf-bg</td><td>#f7f9fc</td><td>#0b1020</td></tr>
      <tr><td>--cf-surface</td><td>#ffffff</td><td>#121827</td></tr>
      <tr><td>--cf-surface-2</td><td>#f0f4f8</td><td>#1c2537</td></tr>
      <tr><td>--cf-text</td><td>#162033</td><td>#eef4ff</td></tr>
      <tr><td>--cf-muted</td><td>#66758c</td><td>#a9b5c8</td></tr>
      <tr><td>--cf-line</td><td>rgba(22,32,51,.12)</td><td>rgba(238,244,255,.14)</td></tr>
      <tr><td>--cf-primary</td><td colspan="2">#ff4785</td></tr>
      <tr><td>--cf-accent</td><td colspan="2">#1ea7fd</td></tr>
    </tbody>
  </table>

  <!-- Typography -->
  <h2 class="h5 mb-3">Typography</h2>
  <div class="cf-preview-card mb-4">
    <div class="d-flex flex-column gap-3">
      <div><span class="h1 d-block mb-0">Heading 1 — 700</span><span class="cf-muted small">$headings-font-weight: 700</span></div>
      <div><span class="h3 d-block mb-0">Heading 3 — 700</span><span class="cf-muted small">Inter, ui-sans-serif, system-ui</span></div>
      <div><span class="d-block mb-0">Body text — 0.9375rem / 1.5 line-height</span><span class="cf-muted small">$font-size-base: .9375rem</span></div>
      <div><code class="cf-mono">Monospace — SFMono-Regular, Consolas</code></div>
      <div><span class="small d-block mb-0">Small text — 0.8125rem</span><span class="cf-muted small">$font-size-sm: .8125rem</span></div>
    </div>
  </div>

  <!-- Radii and shadows -->
  <h2 class="h5 mb-3">Border Radii & Shadows</h2>
  <div class="row g-3 mb-2">
    {[
      [".375rem", "sm", "Inputs, tight UI"],
      [".5rem", "base", "Default"],
      [".75rem", "lg", "Cards, panels"],
      ["99rem", "pill", "Badges"],
    ].map(([r, name, usage]) => (
      <div class="col-6 col-md-3">
        <div style={`background:var(--cf-primary);height:3rem;border-radius:${r};opacity:.85`} class="mb-2"></div>
        <div class="small"><strong>{r}</strong> <span class="cf-muted">— {name}</span></div>
        <div class="cf-muted" style="font-size:.72rem">{usage}</div>
      </div>
    ))}
  </div>

  <div class="row g-3 mt-1 mb-2">
    {[
      ["Shadow SM", "0 8px 24px rgba(18,24,39,.10)"],
      ["Shadow", "0 16px 42px rgba(18,24,39,.12)"],
      ["Shadow LG", "0 28px 80px rgba(18,24,39,.18)"],
    ].map(([label, shadow]) => (
      <div class="col-md-4">
        <div class="p-3 rounded mb-2 bg-white" style={`box-shadow:${shadow}`}>{label}</div>
        <code style="font-size:.72rem">{shadow}</code>
      </div>
    ))}
  </div>

  <!-- Dark mode -->
  <h2 class="h5 mt-4 mb-3">Dark Mode</h2>
  <p class="cf-muted">Add <code>data-bs-theme="dark"</code> to the <code>&lt;html&gt;</code> element. <code>components.js</code> handles this via <code>[data-cf-theme]</code> buttons, with preference stored in <code>localStorage</code>.</p>
  <div class="row g-3">
    <div class="col-md-6">
      <div class="cf-preview-card" data-bs-theme="light">
        <div class="cf-statusbar rounded" style="position:static;border:1px solid var(--cf-line)">
          <span><i class="bi bi-sun me-1"></i>Light mode</span>
          <span>#f7f9fc bg</span>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="rounded p-3" data-bs-theme="dark" style="background:#0b1020; border: 1px solid rgba(238,244,255,.14)">
        <div class="cf-statusbar rounded" style="position:static;border:1px solid rgba(238,244,255,.14)">
          <span><i class="bi bi-moon-stars me-1"></i>Dark mode</span>
          <span>#0b1020 bg</span>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>
