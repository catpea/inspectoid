---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Starters" description="Starter templates that demonstrate different component-workshop variants.">
  <div class="row g-3">
    <div class="col-md-6">
      <a class="cf-story-card" href="/examples/component-workshop/index.html">
        <span class="cf-story-icon"><i class="bi bi-window-sidebar"></i></span>
        <div><h2 class="cf-story-title">Component Workshop</h2><p class="cf-muted mb-0">Default story tree, canvas, and addon panel.</p></div>
      </a>
    </div>
    <div class="col-md-6">
      <a class="cf-story-card" href="/examples/design-system-docs/index.html">
        <span class="cf-story-icon"><i class="bi bi-journal-code"></i></span>
        <div><h2 class="cf-story-title">Design System Docs</h2><p class="cf-muted mb-0">Documentation-first component pages.</p></div>
      </a>
    </div>
    <div class="col-md-6">
      <a class="cf-story-card" href="/examples/testing-dashboard/index.html">
        <span class="cf-story-icon"><i class="bi bi-check2-square"></i></span>
        <div><h2 class="cf-story-title">Testing Dashboard</h2><p class="cf-muted mb-0">Visual, interaction, and accessibility status.</p></div>
      </a>
    </div>
    <div class="col-md-6">
      <a class="cf-story-card" href="/examples/addon-panel/index.html">
        <span class="cf-story-icon"><i class="bi bi-puzzle"></i></span>
        <div><h2 class="cf-story-title">Addon Panel</h2><p class="cf-muted mb-0">Controls-heavy variant for addon authors.</p></div>
      </a>
    </div>
  </div>
</BaseLayout>
