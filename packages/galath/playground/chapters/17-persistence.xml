<!--
  chapters/17-persistence.xml

  Persisting signal values across page loads with <store> and <restore>
  plus a signal-change <listener>.

  The canonical pattern (memorize this):

      <on:mount>
        <restore signal="theme" key="app:theme" default="'light'" />
      </on:mount>

      <listeners>
        <listener signal="theme">
          <store signal="theme" key="app:theme" />
        </listener>
      </listeners>

  Restore once at boot; write on every change. Anything you change in
  the demo below survives a refresh of the page.
-->
<galath xmlns:bind="urn:galath:bind" xmlns:on="urn:galath:on" xmlns:use="urn:galath:use" xmlns:drag="urn:galath:drag" xmlns:drop="urn:galath:drop" xmlns:class="urn:galath:class">
  <component name="chapter-persistence" tag="x-chapter-persistence">
    <model>
      <signal name="theme"    value="light" />
      <signal name="username" value="" />
      <signal name="visits"   value="0" />

      <signal name="snippet"><![CDATA[<model>
  <signal name="theme"    value="light" />
  <signal name="username" value="" />
</model>

<on:mount>
  <restore signal="theme"    key="app:theme"    default="'light'" />
  <restore signal="username" key="app:username" default="''" />
</on:mount>

<listeners>
  <listener signal="theme">
    <store signal="theme" key="app:theme" />
  </listener>
  <listener signal="username">
    <store signal="username" key="app:username" />
  </listener>
</listeners>

<view>
  <input bind:value="username" />
  <select bind:value="theme">
    <option value="light">Light</option>
    <option value="dark">Dark</option>
  </select>
</view>]]></signal>
    </model>

    <on:mount>
      <restore signal="theme"    key="'galath:playground:persistence:theme'"    default="'light'" />
      <restore signal="username" key="'galath:playground:persistence:username'" default="''" />
      <restore signal="visits"   key="'galath:playground:persistence:visits'"   default="0" />
      <set     signal="visits"   value="visits + 1" />
    </on:mount>

    <listeners>
      <listener signal="theme">
        <store signal="theme" key="'galath:playground:persistence:theme'" />
      </listener>
      <listener signal="username">
        <store signal="username" key="'galath:playground:persistence:username'" />
      </listener>
      <listener signal="visits">
        <store signal="visits" key="'galath:playground:persistence:visits'" />
      </listener>
    </listeners>

    <view>
      <div class="px-4 py-5">
        <x-chapter-heading icon="bi-hdd" title="Persistence"
          subtitle="Round-trip signals through localStorage with two operations." />

        <div class="row g-4 mb-4">
          <div class="col-lg-6">
            <div class="card xes-card h-100">
              <div class="card-body">
                <h2 class="h5"><i class="bi bi-journal-text me-2 text-info"></i>How it works</h2>
                <p class="text-secondary">
                  Two operations move JSON between signals and <code>localStorage</code>:
                </p>
                <ul class="text-secondary">
                  <li><code>&lt;restore signal="x" key="..." default="..."/&gt;</code> reads JSON
                      from the given key. On miss (or parse error) the <code>default</code>
                      expression is evaluated and assigned instead. Use it in
                      <code>&lt;on:mount&gt;</code>.</li>
                  <li><code>&lt;store signal="x" key="..."/&gt;</code> writes the current value as
                      JSON. Drive it from a signal-change <code>&lt;listener&gt;</code> so every
                      change is captured.</li>
                </ul>
                <p class="text-secondary mb-0">
                  The <code>key</code> attribute is an <em>expression</em>, not a literal string
                  - wrap it in quotes if you want a fixed key, or compute it to scope storage
                  per-user / per-document.
                </p>
              </div>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="card xes-card h-100">
              <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <strong><i class="bi bi-code-slash me-2"></i>Source</strong>
                <div class="btn-group btn-group-sm" role="group"><button class="btn btn-outline-info" on:click="window.galathRunSnippet(snippet)" title="Open this snippet in a new tab"><i class="bi bi-play-fill me-1"></i>Run</button><button class="btn btn-outline-info" use:copy="snippet" title="Copy to clipboard"><i class="bi bi-clipboard me-1"></i>Copy</button></div>
              </div>
              <div class="card-body p-0">
                <pre class="xes-code rounded p-3 mb-0"><code><text value="snippet" /></code></pre>
              </div>
            </div>
          </div>
        </div>

        <div class="card xes-card">
          <div class="card-header bg-transparent">
            <strong><i class="bi bi-play-circle me-2"></i>Live demo</strong>
          </div>
          <div class="card-body">
            <div class="row g-3 align-items-end">
              <div class="col-md-5">
                <label class="form-label">Your name</label>
                <input class="form-control" placeholder="Type something..." bind:value="username" />
              </div>
              <div class="col-md-4">
                <label class="form-label">Theme</label>
                <select class="form-select" bind:value="theme">
                  <option value="light">Light</option>
                  <option value="dark">Dark</option>
                  <option value="solarized">Solarized</option>
                </select>
              </div>
              <div class="col-md-3">
                <div class="text-secondary small">Visits</div>
                <div class="display-6">{visits}</div>
              </div>
            </div>

            <hr class="my-4" />

            <div class="alert alert-info mb-0">
              <i class="bi bi-info-circle me-1"></i>
              Edit anything above, then refresh the page. The values come back because
              <code>&lt;listener signal="..."&gt;&lt;store/&gt;&lt;/listener&gt;</code> writes
              on every change, and <code>&lt;restore/&gt;</code> reads on mount.
            </div>
          </div>
        </div>
      </div>
    </view>
  </component>
</galath>
