<!--
  chapters/18-async.xml

  <fetch> is the async HTTP operation. It writes the parsed response
  into a signal, flips an optional `loading` signal while the request
  is in flight, and writes any error message into an optional `error`
  signal. The op is fire-and-forget - operations after <fetch> in the
  same block run immediately, before the response resolves.

  This chapter uses jsonplaceholder.typicode.com - a free, CORS-enabled
  REST mock that works offline if the request is cached.
-->
<galath xmlns:bind="urn:galath:bind" xmlns:on="urn:galath:on" xmlns:use="urn:galath:use" xmlns:drag="urn:galath:drag" xmlns:drop="urn:galath:drop" xmlns:class="urn:galath:class">
  <component name="chapter-async" tag="x-chapter-async">
    <model>
      <signal name="userId"  value="1" />
      <signal name="todo"    value="" />
      <signal name="loading" value="false" />
      <signal name="error"   value="" />

      <signal name="postTitle" value="" />
      <signal name="postBody"  value="" />
      <signal name="created"   value="" />
      <signal name="postingLoading" value="false" />
      <signal name="postingError"   value="" />

      <signal name="snippet"><![CDATA[<model>
  <signal name="userId"  value="1" />
  <signal name="todo"    value="" />
  <signal name="loading" value="false" />
  <signal name="error"   value="" />
</model>

<controller>
  <action name="loadTodo">
    <fetch url="'https://jsonplaceholder.typicode.com/todos/' + userId"
           into="todo"
           loading="loading"
           error="error" />
  </action>

  <!-- POST with a JSON body. Object-typed `body` auto-encodes and sets
       Content-Type: application/json. -->
  <action name="createPost">
    <fetch url="'https://jsonplaceholder.typicode.com/posts'"
           method="POST"
           body="{ title: postTitle, body: postBody, userId: 1 }"
           into="created"
           loading="postingLoading"
           error="postingError" />
  </action>
</controller>

<on:mount>
  <call action="loadTodo" />
</on:mount>

<view>
  <input bind:value="userId" />
  <button on:click="#loadTodo">Load</button>
  <if test="loading">Loading...</if>
  <if test="!loading and todo">Title: {todo.title}</if>
  <if test="error"><span class="text-danger">{error}</span></if>
</view>]]></signal>
    </model>

    <controller>
      <action name="loadTodo">
        <fetch url="'https://jsonplaceholder.typicode.com/todos/' + userId"
               into="todo"
               loading="loading"
               error="error" />
      </action>

      <action name="createPost">
        <fetch url="'https://jsonplaceholder.typicode.com/posts'"
               method="POST"
               body="{ title: postTitle, body: postBody, userId: 1 }"
               into="created"
               loading="postingLoading"
               error="postingError" />
      </action>
    </controller>

    <on:mount>
      <call action="loadTodo" />
    </on:mount>

    <view>
      <div class="px-4 py-5">
        <x-chapter-heading icon="bi-cloud-download" title="Async (fetch)"
          subtitle="Load and submit data without writing async JavaScript by hand." />

        <div class="row g-4 mb-4">
          <div class="col-lg-6">
            <div class="card xes-card h-100">
              <div class="card-body">
                <h2 class="h5"><i class="bi bi-journal-text me-2 text-info"></i>How it works</h2>
                <p class="text-secondary">
                  <code>&lt;fetch&gt;</code> wraps <code>window.fetch</code> with three
                  signal-aware side-effects:
                </p>
                <ul class="text-secondary">
                  <li><code>into="sig"</code> - the parsed response value goes here.</li>
                  <li><code>loading="sig"</code> - flipped to <code>true</code> on send,
                      <code>false</code> on settle.</li>
                  <li><code>error="sig"</code> - error message, or an empty string on success.</li>
                </ul>
                <p class="text-secondary">
                  Optional attributes:
                </p>
                <ul class="text-secondary mb-3">
                  <li><code>method</code> - <code>GET</code>, <code>POST</code>, anything HTTP.</li>
                  <li><code>body</code> - evaluated expression. Plain objects are
                      <code>JSON.stringify</code>-ed; strings/FormData/Blob/URLSearchParams
                      are sent as-is.</li>
                  <li><code>headers</code> - evaluated expression yielding a header object.</li>
                  <li><code>as="json|text|response"</code> - response parser. Defaults to JSON.</li>
                </ul>
                <p class="text-secondary mb-0">
                  <strong>Fire and forget.</strong> Operations after <code>&lt;fetch&gt;</code>
                  in the same block run synchronously. Use a <code>&lt;listener
                  signal="into"&gt;</code> if you need to react to the eventual result.
                </p>
              </div>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="card xes-card h-100">
              <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <strong><i class="bi bi-code-slash me-2"></i>Source</strong>
                <div class="btn-group btn-group-sm" role="group"><button class="btn btn-outline-info" on:click="window.galathRunSnippet(snippet)" title="Open this snippet in a new tab"><i class="bi bi-play-fill me-1"></i>Run</button><button class="btn btn-outline-info" use:copy="snippet" title="Copy to clipboard"><i class="bi bi-clipboard me-1"></i>Copy</button></div>
              </div>
              <div class="card-body p-0">
                <pre class="xes-code rounded p-3 mb-0"><code><text value="snippet" /></code></pre>
              </div>
            </div>
          </div>
        </div>

        <div class="card xes-card">
          <div class="card-header bg-transparent">
            <strong><i class="bi bi-arrow-down-circle me-2"></i>GET demo</strong>
          </div>
          <div class="card-body">
            <div class="row g-3 align-items-end mb-3">
              <div class="col-md-3">
                <label class="form-label">Todo id</label>
                <input class="form-control" type="number" min="1" max="200" bind:value="userId" />
              </div>
              <div class="col-md-3">
                <button class="btn btn-info w-100" on:click="#loadTodo" disabled="{loading}">
                  <i class="bi bi-arrow-clockwise me-1"></i>
                  <if test="loading">Loading...</if>
                  <if test="!loading">Reload</if>
                </button>
              </div>
              <div class="col-md-6 text-secondary xes-tiny">
                Hits <code>jsonplaceholder.typicode.com/todos/{userId}</code>. Try ids 1-200.
              </div>
            </div>

            <if test="error">
              <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>{error}</div>
            </if>
            <if test="!error and !loading and todo">
              <div class="card xes-card">
                <div class="card-body">
                  <div class="text-secondary xes-tiny mb-1">todo &#xB7; id {todo.id}</div>
                  <div class="h5 mb-2">{todo.title}</div>
                  <div>
                    <span class="badge text-bg-{todo.completed ? 'success' : 'secondary'}">
                      <if test="todo.completed">completed</if>
                      <if test="!todo.completed">open</if>
                    </span>
                  </div>
                </div>
              </div>
            </if>
          </div>
        </div>

        <div class="card xes-card mt-4">
          <div class="card-header bg-transparent">
            <strong><i class="bi bi-arrow-up-circle me-2"></i>POST demo</strong>
          </div>
          <div class="card-body">
            <div class="row g-3 mb-3">
              <div class="col-md-5">
                <label class="form-label">Title</label>
                <input class="form-control" bind:value="postTitle" />
              </div>
              <div class="col-md-5">
                <label class="form-label">Body</label>
                <input class="form-control" bind:value="postBody" />
              </div>
              <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-success w-100" on:click="#createPost" disabled="{postingLoading}">
                  <if test="postingLoading">Sending...</if>
                  <if test="!postingLoading">Create</if>
                </button>
              </div>
            </div>

            <if test="postingError">
              <div class="alert alert-danger">{postingError}</div>
            </if>
            <if test="created">
              <div class="alert alert-success">
                <i class="bi bi-check-circle me-1"></i>
                Server responded with id <strong>{created.id}</strong>:
                <pre class="mb-0 xes-tiny">{JSON.stringify(created, null, 2)}</pre>
              </div>
            </if>
          </div>
        </div>
      </div>
    </view>
  </component>
</galath>
