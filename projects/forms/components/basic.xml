<component name="story-form-basic" tag="x-story-form-basic">
  <view>
    <form class="inspectoid-story-form">
      <div class="mb-3">
        <label for="basicName" class="form-label">Full Name</label>
        <input type="text" class="form-control" id="basicName" placeholder="Jane Doe" />
      </div>
      <div class="mb-3">
        <label for="basicEmail" class="form-label">Email address</label>
        <input type="email" class="form-control" id="basicEmail" placeholder="name@example.com" />
        <div class="form-text">We will never share your email with anyone else.</div>
      </div>
      <div class="mb-3">
        <label for="basicSubject" class="form-label">Subject</label>
        <select class="form-select" id="basicSubject">
          <option value="">Choose a topic...</option>
          <option value="support">Support</option>
          <option value="sales">Sales</option>
          <option value="general">General inquiry</option>
        </select>
      </div>
      <div class="mb-3">
        <label for="basicMessage" class="form-label">Message</label>
        <textarea class="form-control" id="basicMessage" rows="4" placeholder="How can we help?"></textarea>
      </div>
      <div class="mb-3 form-check">
        <input type="checkbox" class="form-check-input" id="basicConsent" />
        <label class="form-check-label" for="basicConsent">I agree to the privacy policy</label>
      </div>
      <button type="submit" class="btn btn-primary">Send message</button>
      <button type="reset" class="btn btn-outline-secondary ms-2">Clear</button>
    </form>
  </view>
</component>
