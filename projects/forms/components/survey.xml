<component name="story-form-survey" tag="x-story-form-survey">
  <view>
    <form class="inspectoid-story-form">
      <fieldset class="mb-3">
        <legend class="form-label">How was your experience?</legend>
        <div class="d-flex flex-wrap gap-3">
          <div class="form-check">
            <input class="form-check-input" type="radio" name="surveyRating" id="surveyRating1" value="1" />
            <label class="form-check-label" for="surveyRating1">1</label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="surveyRating" id="surveyRating2" value="2" />
            <label class="form-check-label" for="surveyRating2">2</label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="surveyRating" id="surveyRating3" value="3" checked="checked" />
            <label class="form-check-label" for="surveyRating3">3</label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="surveyRating" id="surveyRating4" value="4" />
            <label class="form-check-label" for="surveyRating4">4</label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="surveyRating" id="surveyRating5" value="5" />
            <label class="form-check-label" for="surveyRating5">5</label>
          </div>
        </div>
      </fieldset>
      <div class="mb-3">
        <label for="surveySatisfaction" class="form-label">Satisfaction</label>
        <select class="form-select" id="surveySatisfaction">
          <option value="">Choose one...</option>
          <option value="very-satisfied">Very satisfied</option>
          <option value="satisfied" selected="selected">Satisfied</option>
          <option value="neutral">Neutral</option>
          <option value="unsatisfied">Unsatisfied</option>
        </select>
      </div>
      <fieldset class="mb-3">
        <legend class="form-label">What should we improve?</legend>
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="surveySpeed" value="speed" checked="checked" />
          <label class="form-check-label" for="surveySpeed">Speed</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="surveyDocs" value="docs" />
          <label class="form-check-label" for="surveyDocs">Documentation</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="surveyDesign" value="design" />
          <label class="form-check-label" for="surveyDesign">Interface design</label>
        </div>
      </fieldset>
      <div class="mb-3">
        <label for="surveyComments" class="form-label">Comments</label>
        <textarea class="form-control" id="surveyComments" rows="4" placeholder="Add details that would help the team."></textarea>
      </div>
      <div class="mb-3">
        <label for="surveyEmail" class="form-label">Email for follow-up</label>
        <input type="email" class="form-control" id="surveyEmail" placeholder="optional@example.com" />
      </div>
      <button type="submit" class="btn btn-primary">Submit survey</button>
      <button type="reset" class="btn btn-outline-secondary ms-2">Clear</button>
    </form>
  </view>
</component>
